# Supabase（プロジェクト設定 → API からコピー）
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# サーバー専用（絶対にクライアントへ出さない）。Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 運営（admin）ログイン用パスコード
ADMIN_PASSCODE=lumina-admin

# 署名付きセッションcookie用シークレット（ランダムな長い文字列に変更）
SESSION_SECRET=change-me-to-a-long-random-string

# メール通知（任意）。設定すると撮影リクエスト時に運営へメールが届く。
# 未設定なら通知は送られず、予約自体は通常どおり成立する。
# RESEND_API_KEY … https://resend.com で取得したAPIキー
# NOTIFY_EMAIL   … 通知を受け取る運営のメールアドレス
# NOTIFY_FROM    … 差出人（任意）。独自ドメインをResendで検証すると到達率が上がる。
#                  未設定時は検証不要の onboarding@resend.dev から送信（テスト用）。
RESEND_API_KEY=
NOTIFY_EMAIL=
NOTIFY_FROM=lumina <onboarding@resend.dev>

